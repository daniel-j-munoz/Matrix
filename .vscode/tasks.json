{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "g++",
            "args": [
                "-g",
                "*.cpp",
                "Libraries/*.cpp",
                "-std=c++23",
                "-o",
                "app",
                "-Iimports/opencv/include/opencv4",
                "-Limports/opencv/lib",
                "-lopencv_core",
                "-lopencv_imgcodecs",
                "-lopencv_highgui",
                "-lopencv_imgproc",
                "&&",
                "./app"
            ],
            "group": "build"
        }
    ]
}